# Local environment values for permitIQ
# Copy this file to .env and fill in your own values.

DB_URL=jdbc:mysql://permit.c7oeqm4qgl5w.ap-south-1.rds.amazonaws.com:3306/permitdb?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=admin
DB_PASSWORD=your_db_password
SERVER_PORT=5000
JWT_SECRET=your_jwt_secret_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
EXPIRING_SOON_DAYS=30
STATUS_REFRESH_CRON=0 0 * * * *
DAILY_REMINDER_CRON=0 0 9 * * *
